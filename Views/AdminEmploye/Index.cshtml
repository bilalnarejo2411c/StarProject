@model IEnumerable<Star_Project.Models.adminreg>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminNav.cshtml";
}

<style>
    h1 {
        font-family: 'Playfair Display', serif;
        color: var(--gold);
        margin-bottom: 25px;
        font-size: 38px;
        font-weight: 700;
    }

    .table-container {
        background: var(--dark2);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 25px;
        margin: 25px;
        overflow: hidden;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        background: transparent;
    }

        .table thead {
            background: var(--dark3);
        }

            .table thead th {
                padding: 18px;
                text-align: left;
                color: var(--gold);
                font-family: 'Playfair Display', serif;
                font-size: 16px;
                border-bottom: 1px solid var(--border);
            }

        .table tbody td {
            padding: 16px 18px;
            color: var(--text);
            border-bottom: 1px solid var(--border);
            font-family: 'DM Sans', sans-serif;
        }

        .table tbody tr {
            transition: all 0.3s ease;
        }

            .table tbody tr:hover {
                background: rgba(201,168,76,0.08);
            }

            .table tbody tr:last-child td {
                border-bottom: none;
            }

    .delete-btn {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 8px;
        border: 1px solid #dc3545;
        color: #dc3545 !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .delete-btn:hover {
            background: #dc3545;
            color: white !important;
            text-decoration: none;
        }

    @@media (max-width: 768px) {

        .table-container {
            margin: 15px;
            padding: 15px;
        }

        h1 {
            font-size: 28px;
        }

        .table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }
    }
</style>

<div class="table-container">
    <h1>Currently Available Employees</h1>

    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.name)</th>
                <th>@Html.DisplayNameFor(model => model.email)</th>
                <th>@Html.DisplayNameFor(model => model.password)</th>
                <th>@Html.DisplayNameFor(model => model.UserRole)</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.name)</td>
                    <td>@Html.DisplayFor(modelItem => item.email)</td>
                    <td>@Html.DisplayFor(modelItem => item.password)</td>
                    <td>@Html.DisplayFor(modelItem => item.UserRole)</td>
                    <td>
                        <a href="@Url.Action("Delete", "AdminEmploye", new { id = item.Id })"
                           onclick="return confirm('Delete @item.name ?');"
                           class="delete-btn">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
