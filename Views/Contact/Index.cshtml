@{
    ViewBag.Title = "Contact Us";
    ViewBag.ActivePage = "Contact";
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: '@TempData["Success"]',
            showConfirmButton: false,
            timer: 2000
        });
    </script>
}
<div class="section-inner">
    <p class="section-tag">Reach Out</p>
    <h2 class="section-title">Contact Us</h2>


    <div class="contact-grid">

        <!-- LEFT: Contact Info -->
        <div>
            <p style="color:var(--muted); font-size:15px; line-height:1.7; margin-bottom:40px;">
                Have a security requirement? Our team is available 24/7 to discuss your
                needs and provide a customized solution.
            </p>

            <div class="contact-info-item">
                <div class="contact-icon">&#x1F3E2;</div>
                <div>
                    <h4>Head Office</h4>
                    <p>
                        Star Securities Pvt. Ltd.<br />
                        14th Floor, Infinity Tower,<br />
                        Sector 25, Gurgaon &ndash; 122001
                    </p>
                </div>
            </div>

            <div class="contact-info-item">
                <div class="contact-icon">&#x1F4DE;</div>
                <div>
                    <h4>Phone</h4>
                    <p>
                        +91-124-XXXXXXX<br />
                        Toll Free: 1800-XXX-XXXX
                    </p>
                </div>
            </div>

            <div class="contact-info-item">
                <div class="contact-icon">&#x1F4E7;</div>
                <div>
                    <h4>Email</h4>
                    <p>
                        info@starsecurities.in<br />
                        careers@starsecurities.in
                    </p>
                </div>
            </div>

            <div class="contact-info-item">
                <div class="contact-icon">&#x1F550;</div>
                <div>
                    <h4>Hours</h4>
                    <p>
                        Operations: 24 &times; 7 &times; 365<br />
                        Office: Mon&ndash;Sat, 9am&ndash;6pm
                    </p>
                </div>
            </div>
        </div>

        <!-- RIGHT: Contact Form -->
        <div class="contact-form-box">
            <h3>Send Us a Message</h3>

            @using (Html.BeginForm("Submit", "Contact", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text" name="FirstName" placeholder="Jawed" />
                    </div>
                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" name="LastName" placeholder="Akhtar" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Company</label>
                    <input type="text" name="Company" placeholder="Your Company Name" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="Email" placeholder="you@company.com" />
                </div>

                <div class="form-group">
                    <label>Phone</label>
                    <input type="tel" name="Phone" placeholder="+91 98XXXXXXXX" />
                </div>

                <div class="form-group">
                    <label>Service Required</label>
                    <select name="Service">
                        <option value="">-- Select Service --</option>
                        <option value="MG">Manned Guarding</option>
                        <option value="CS">Cash Services</option>
                        <option value="ESS">Electronic Security</option>
                        <option value="RT">Recruitment &amp; Training</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Message</label>
                    <textarea name="Message" placeholder="Describe your security requirement..."></textarea>
                </div>

                <button type="submit" class="btn-gold" style="width:100%;">
                    Submit Enquiry
                </button>
            }
        </div>

    </div>
</div>
