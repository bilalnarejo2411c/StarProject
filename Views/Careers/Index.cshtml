@model IEnumerable<Star_Project.Models.AdminVaccanies>

@{
    ViewBag.Title = "Careers";
    ViewBag.ActivePage = "Careers";
}

<div class="section-inner">
    <p class="section-tag">Join Our Team</p>
    <h2 class="section-title">Current Openings</h2>
    <p class="section-sub">
        Be part of our trusted security force. We hire, train and grow talent.
    </p>

    @if (Model != null && Model.Any())
    {
        @foreach (var job in Model)
        {
            <div class="job-card">
                <div class="job-info">
                    <h3>@job.Name</h3>

                    <p>@job.Criteria</p>

                    <div class="job-meta">
                        <span>&#x1F4CD; @job.Location</span>
                        <span>&#x1F4BC; @job.Postiton</span>
                        <span>&#x1F393; @job.Age</span>
                        <span>&#x1F3D9; @job.City</span>
                    </div>
                </div>

                <a href="@Url.Action("Apply", "Careers", new { id = job.Id })"
                   class="btn-outline-sm">
                    Apply Now
                </a>
            </div>
        }
    }
    else
    {
        <div class="job-card">
            <div class="job-info">
                <h3>No Vacancies Available</h3>
                <p>
                    There are currently no open positions.
                    Please check back later.
                </p>
            </div>
        </div>
    }

    <p style="color:var(--muted); font-size:13px; margin-top:8px; text-align:center;">
        Vacancies are managed by the Admin. Filled positions are removed automatically.
    </p>
</div>
