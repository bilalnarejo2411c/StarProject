@{
    ViewBag.Title = "Employee Login";
    ViewBag.ActivePage = "";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page">
    <div class="login-card">

        <div class="login-icon">&#x1F510;</div>
        <h2>Employee Portal</h2>
        <p class="login-sub">
            Access is restricted to authorized Star Securities employees only.
            No self-registration is permitted.
        </p>

        @if (ViewBag.Error != null)
        {
            <div style="background:rgba(226,75,74,0.1); border:1px solid rgba(226,75,74,0.3); color:#E24B4A; padding:12px 16px; border-radius:8px; font-size:14px; margin-bottom:20px;">
                @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Employee Name</label>
                <input type="text" name="email" placeholder="e.g. Ali" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
            </div>

            <button type="submit" class="btn-gold" style="width:100%; margin-top:8px;">
                Sign In
            </button>
        }

        <div class="login-footer">
            Not an employee? &nbsp;
            <a href="@Url.Action("Index", "Contact")">Contact HR</a>
        </div>

    </div>
</div>
