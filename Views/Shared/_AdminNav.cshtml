    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewBag.Title - Star Securities Admin</title>

        <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet" />
        <link href="~/css/star.css" rel="stylesheet" />
        <link href="~/Content/css/star.css" rel="stylesheet" />

        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            .admin-navbar {
                font-family: 'Syne', sans-serif;
                background: #0f1117;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                padding: 0 20px;
                height: 60px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .admin-nav-left {
                display: flex;
                align-items: center;
                gap: 20px;
            }

            .admin-logo {
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
                flex-shrink: 0;
            }

            .admin-logo-icon {
                width: 32px;
                height: 32px;
                background: linear-gradient(135deg, #6c63ff, #4ecdc4);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                color: white;
            }

            .admin-logo-text {
                font-size: 16px;
                font-weight: 700;
                color: #fff;
                letter-spacing: -0.3px;
            }

            .admin-logo-sub {
                font-size: 11px;
                color: rgba(255,255,255,0.4);
                font-weight: 400;
                display: block;
                margin-top: 1px;
            }

            .admin-logo-badge {
                font-size: 10px;
                font-weight: 600;
                color: #6c63ff;
                background: rgba(108,99,255,0.15);
                border: 1px solid rgba(108,99,255,0.3);
                padding: 2px 7px;
                border-radius: 4px;
                letter-spacing: 0.5px;
            }

            .admin-nav-links {
                display: flex;
                align-items: center;
                gap: 2px;
                list-style: none;
            }

                .admin-nav-links a {
                    display: flex;
                    align-items: center;
                    gap: 6px;
                    padding: 6px 10px;
                    border-radius: 7px;
                    font-size: 12.5px;
                    font-weight: 500;
                    color: rgba(255,255,255,0.5);
                    text-decoration: none;
                    transition: all 0.2s;
                    white-space: nowrap;
                }

                    .admin-nav-links a:hover {
                        color: #fff;
                        background: rgba(255,255,255,0.06);
                    }

                    .admin-nav-links a.active {
                        color: #fff;
                        background: rgba(108,99,255,0.18);
                    }

            .admin-active-dot {
                display: none;
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: #6c63ff;
                flex-shrink: 0;
            }

            .admin-nav-links a.active .admin-active-dot {
                display: block;
            }

            .admin-nav-links i {
                font-size: 15px;
                flex-shrink: 0;
            }

            .admin-nav-right {
                display: flex;
                align-items: center;
                gap: 6px;
                flex-shrink: 0;
            }

            .admin-icon-btn {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                border: none;
                background: transparent;
                color: rgba(255,255,255,0.45);
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: all 0.2s;
                font-size: 18px;
                position: relative;
            }

                .admin-icon-btn:hover {
                    background: rgba(255,255,255,0.07);
                    color: #fff;
                }

            .admin-notif-dot {
                position: absolute;
                top: 6px;
                right: 6px;
                width: 8px;
                height: 8px;
                background: #ff4d6a;
                border-radius: 50%;
                border: 1.5px solid #0f1117;
            }

            .admin-nav-divider {
                width: 1px;
                height: 22px;
                background: rgba(255,255,255,0.1);
                margin: 0 2px;
            }

            .admin-user-btn {
                display: flex;
                align-items: center;
                gap: 9px;
                padding: 5px 10px 5px 5px;
                border-radius: 8px;
                border: 1px solid rgba(255,255,255,0.08);
                background: rgba(255,255,255,0.04);
                cursor: pointer;
                transition: all 0.2s;
                color: #fff;
                font-family: 'Syne', sans-serif;
            }

                .admin-user-btn:hover {
                    background: rgba(255,255,255,0.08);
                    border-color: rgba(255,255,255,0.14);
                }

            .admin-avatar {
                width: 28px;
                height: 28px;
                border-radius: 7px;
                background: linear-gradient(135deg, #f093fb, #f5576c);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                font-weight: 700;
                color: white;
                letter-spacing: -0.5px;
            }

            .admin-user-name {
                font-size: 13px;
                font-weight: 600;
                color: #fff;
            }

            .admin-user-role {
                font-size: 11px;
                color: rgba(255,255,255,0.4);
                margin-top: 1px;
            }

            .admin-user-btn i {
                font-size: 14px;
                color: rgba(255,255,255,0.3);
            }

            .admin-logout-btn {
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 7px 12px;
                border-radius: 7px;
                border: 1px solid rgba(255,77,106,0.3);
                background: rgba(255,77,106,0.08);
                color: #ff4d6a;
                font-size: 12.5px;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.2s;
                font-family: 'Syne', sans-serif;
                white-space: nowrap;
                text-decoration: none;
            }

                .admin-logout-btn:hover {
                    background: rgba(255,77,106,0.18);
                    border-color: rgba(255,77,106,0.5);
                }

                .admin-logout-btn i {
                    font-size: 15px;
                }
        </style>

        @RenderSection("styles", required: false)
    </head>
    <body>

        <!-- ===== ADMIN NAVBAR ===== -->
        <nav class="admin-navbar">
            <div class="admin-nav-left">

                <a href="@Url.Action("Home", "Admin")" class="admin-logo">
                    <div class="admin-logo-icon">
                        <i class="ti ti-shield-check"></i>
                    </div>
                    <div>
                        <span class="admin-logo-text">&#9733; STAR</span>
                        <span class="admin-logo-sub">Securities Admin</span>
                    </div>
                    <span class="admin-logo-badge">ADMIN</span>
                </a>

                <ul class="admin-nav-links">
                    <li>
                        <a href="@Url.Action("Index", "Applicants")"
                           class="@(ViewBag.ActivePage == "Applicants" ? "active" : "")">
                            <i class="ti ti-layout-dashboard"></i>
                            Applicants
                            <span class="admin-active-dot"></span>
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "AdminRegistration")"
                           class="@(ViewBag.ActivePage == "Registration" ? "active" : "")">
                            <i class="ti ti-users"></i>
                            Registration
                            <span class="admin-active-dot"></span>
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "AdminComplaints")"
                           class="@(ViewBag.ActivePage == "Complaints" ? "active" : "")">
                            <i class="ti ti-message-report"></i>
                            Complaints
                            <span class="admin-active-dot"></span>
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "AdminEmployee")"
                           class="@(ViewBag.ActivePage == "Employee" ? "active" : "")">
                            <i class="ti ti-id-badge"></i>
                            Employee
                            <span class="admin-active-dot"></span>
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "AdminVacancies")"
                           class="@(ViewBag.ActivePage == "Vacancies" ? "active" : "")">
                            <i class="ti ti-briefcase"></i>
                            Vacancies
                            <span class="admin-active-dot"></span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="admin-nav-right">
                <button class="admin-icon-btn">
                    <i class="ti ti-search"></i>
                </button>
                <button class="admin-icon-btn">
                    <i class="ti ti-bell"></i>
                    <span class="admin-notif-dot"></span>
                </button>

                <div class="admin-nav-divider"></div>

                <button class="admin-user-btn">
                    <div class="admin-avatar">AD</div>
                    <div>
                        <div class="admin-user-name">
                            @(User.Identity != null && User.Identity.IsAuthenticated ? User.Identity.Name : "Admin")
                        </div>
                        <div class="admin-user-role">Administrator</div>
                    </div>
                    <i class="ti ti-chevron-down"></i>
                </button>

                <div class="admin-nav-divider"></div>

                <a href="@Url.Action("Logout", "AdminData")" class="admin-logout-btn">
                    <i class="ti ti-logout"></i>
                    Logout
                </a>
            </div>
        </nav>

        <!-- ===== PAGE CONTENT ===== -->
        <main>
            @RenderBody()
        </main>

      
        <script src="~/Scripts/jquery"></script>
        <script src="~/Scripts/"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        @RenderSection("scripts", required: false)

    </body>
    </html>
}
