<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Star Securities</title>

    @* Google Fonts *@
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

    @* Bootstrap (optional, for grid fallback) *@
    <link href="~/css/star.css" rel="stylesheet" />

    @* Star Securities Custom CSS *@
    <link href="~/Content/css/star.css" rel="stylesheet" />

    @RenderSection("styles", required: false)
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar-star">
        <a href="@Url.Action("Index", "Home")" class="navbar-logo">
            &#9733; STAR
            <span>Securities</span>
        </a>

        <ul class="navbar-links">
            <li>
                <a href="@Url.Action("Index", "Home")"
                   class="@(ViewBag.ActivePage == "Home" ? "active" : "")">
                    Home
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "About")"
                   class="@(ViewBag.ActivePage == "About" ? "active" : "")">
                    About
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Services")"
                   class="@(ViewBag.ActivePage == "Services" ? "active" : "")">
                    Services
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Network")"
                   class="@(ViewBag.ActivePage == "Network" ? "active" : "")">
                    Network
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Clients")"
                   class="@(ViewBag.ActivePage == "Clients" ? "active" : "")">
                    Clients
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Careers")"
                   class="@(ViewBag.ActivePage == "Careers" ? "active" : "")">
                    Careers
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Contact")"
                   class="@(ViewBag.ActivePage == "Contact" ? "active" : "")">
                   Contact Us
                </a>

            </li>
            <li>
                <a href="@Url.Action("Sitemap", "Home")"
                   class="@(ViewBag.ActivePage == "Home" ? "active" : "")">
                    Navigation
                </a>

            </li>
            <li>
                <a href="@Url.Action("Index", "Hiring")"
                   class="@(ViewBag.ActivePage == "Home" ? "active" : "")">
                    Hiring Form
                </a>

            </li>
        </ul>

        <a href="@Url.Action("Login", "Account")" class="navbar-btn">
            Employee Login
        </a>
    </nav>

    <!-- ===== PAGE CONTENT ===== -->
    <main>
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
        <div class="footer-inner">
            <div class="footer-grid">
                <div class="footer-brand">
                    <span class="navbar-logo">&#9733; STAR Securities</span>
                    <p>
                        Total Security Solutions Provider serving corporate India since 2000.
                        Manned guarding, cash services, electronic security and more.
                    </p>
                    <span class="iso-badge">ISO 9001:2000</span>
                </div>
                <div class="footer-col">
                    <h4>Company</h4>
                    <a href="@Url.Action("Index", "About")">About Us</a>
                    <a href="@Url.Action("Index", "About")">Chairman's Profile</a>
                    <a href="@Url.Action("Index", "About")">Board of Directors</a>
                    <a href="@Url.Action("Index", "Network")">Our Network</a>
                </div>
                <div class="footer-col">
                    <h4>Services</h4>
                    <a href="@Url.Action("Index", "Services")">Manned Guarding</a>
                    <a href="@Url.Action("Index", "Services")">Cash Services</a>
                    <a href="@Url.Action("Index", "Services")">Electronic Security</a>
                    <a href="@Url.Action("Index", "Services")">Recruitment</a>
                </div>
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <a href="@Url.Action("Index", "Clients")">Clients</a>
                    <a href="@Url.Action("Index", "Careers")">Careers</a>
                    <a href="@Url.Action("Index", "Contact")">Contact Us</a>
                    <a href="@Url.Action("Login", "Account")">Employee Login</a>
                    <a href="@Url.Action("Sitemap", "Home")">Site Map</a>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; @DateTime.Now.Year Star Securities Pvt. Ltd. All rights reserved.</span>
                <span>Privacy Policy &middot; Terms of Use</span>
            </div>
        </div>
    </footer>

    @* Scripts *@
    <script src="~/Scripts/jquery"></script>
    <script src="~/Scripts/"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @RenderSection("scripts", required: false)

</body>
</html>
