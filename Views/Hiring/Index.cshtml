@model Star_Project.Models.Hiring

@{
    ViewData["Title"] = "Join Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: '@TempData["Success"]',
            showConfirmButton: false,
            timer: 2000
        });
    </script>
}

<style>
    .text-danger {
        color: red;
        font-size: 13px;
        display: block;
        margin-top: 5px;
    }
</style>

<div class="section-inner">
    <p class="section-tag">Career Opportunity</p>
    <h2 class="section-title">Join Our Team</h2>

    <div class="contact-grid">

        <!-- LEFT SIDE -->
        <div>
            <p style="color:var(--muted); font-size:15px; line-height:1.7; margin-bottom:40px;">
                Join our professional security team. Fill out the application form and our HR department will contact you.
            </p>

            <div class="contact-info-item">
                <div class="contact-icon">&#x1F3E2;</div>
                <div>
                    <h4>Head Office</h4>
                    <p>
                        Star Securities Pvt. Ltd.<br />
                        HR Department
                    </p>
                </div>
            </div>
        </div>

        <!-- RIGHT SIDE FORM -->
        <div class="contact-form-box">
            <h3>Job Application Form</h3>

            @using (Html.BeginForm("Submit", "Hiring", FormMethod.Post))
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text"
                               name="FirstName"
                               value="@Model?.FirstName" />

                        @Html.ValidationMessage("FirstName", "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text"
                               name="LastName"
                               value="@Model?.LastName" />

                        @Html.ValidationMessage("LastName", "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email"
                           name="Email"
                           value="@Model?.Email" />

                    @Html.ValidationMessage("Email", "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="number"
                           name="Phone"
                           value="@Model?.Phone" />

                    @Html.ValidationMessage("Phone", "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label>Education</label>
                    <select name="Education">
                        <option value="">Select Education</option>
                        <option value="Matric">Matric</option>
                        <option value="Intermediate">Intermediate</option>
                        <option value="Bachelor">Bachelor</option>
                        <option value="Master">Master</option>
                    </select>

                    @Html.ValidationMessage("Education", "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label>Profession</label>
                    <select name="Profession">
                        <option value="">Select Profession</option>
                        <option value="Security Guard">Security Guard</option>
                        <option value="Supervisor">Supervisor</option>
                        <option value="Driver">Driver</option>
                        <option value="Control Room Operator">Control Room Operator</option>
                        <option value="Office Assistant">Office Assistant</option>
                    </select>

                    @Html.ValidationMessage("Profession", "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn-gold" style="width:100%;">
                    Submit Application
                </button>
            }
        </div>

    </div>
</div>