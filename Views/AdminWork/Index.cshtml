@model IEnumerable<Star_Project.Models.Contact>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminNav.cshtml";
}

<h1>Admin Work Contact Us Details</h1>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Service)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Message)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Company)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Service)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Message)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">
                            Delete
                        </button>
                    </form>
            </td>
        </tr>
}
    </tbody>
</table>

<style>
    body {
        background: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    h1 {
        color: #6f42c1;
        margin-bottom: 20px;
        font-weight: 700;
    }

    p a {
        display: inline-block;
        text-decoration: none !important;
        background: #6f42c1;
        color: white !important;
        padding: 10px 18px;
        border-radius: 6px;
        font-weight: 500;
        margin-bottom: 20px;
        transition: 0.3s;
    }

        p a:hover {
            background: #5a32a3;
            color: white !important;
        }

    .table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

        .table thead tr {
            background: #f3e8ff !important;
        }

        .table thead th {
            color: #6f42c1 !important;
            background: #f3e8ff !important;
            padding: 15px !important;
            font-weight: 700 !important;
            border-bottom: 2px solid #6f42c1 !important;
        }

        .table tbody td {
            color: #6f42c1 !important;
            padding: 14px !important;
            border-bottom: 1px solid #ddd;
            vertical-align: middle;
        }

        .table tbody tr:nth-child(even) {
            background: #faf7ff;
        }

        .table tbody tr:hover {
            background: #f0e6ff;
        }

        .table tbody a {
            text-decoration: none;
            font-weight: 600;
            margin-right: 5px;
        }

            .table tbody a:nth-child(1) {
                color: #198754 !important;
            }

            .table tbody a:nth-child(2) {
                color: #0d6efd !important;
            }

            .table tbody a:nth-child(3) {
                color: #dc3545 !important;
            }

            .table tbody a:hover {
                text-decoration: underline;
            }
</style>