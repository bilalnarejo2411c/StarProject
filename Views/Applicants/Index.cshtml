@model IEnumerable<Star_Project.Models.Hiring>

@{
    ViewData["Title"] = "Applicants";
    Layout = "~/Views/Shared/_AdminNav.cshtml";
}

<div class="table-container">

    ```
    <div class="page-header">
        <h1>Job Applicants</h1>

        <a asp-action="Create" class="btn-gold">
            Create New
        </a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.FirstName)</th>
                <th>@Html.DisplayNameFor(model => model.LastName)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th>@Html.DisplayNameFor(model => model.Phone)</th>
                <th>@Html.DisplayNameFor(model => model.Education)</th>
                <th>@Html.DisplayNameFor(model => model.Profession)</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.FirstName)</td>
                    <td>@Html.DisplayFor(modelItem => item.LastName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                    <td>@Html.DisplayFor(modelItem => item.Education)</td>
                    <td>@Html.DisplayFor(modelItem => item.Profession)</td>

                    <td class="action-cell">

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="details-btn">
                            Details
                        </a>

                        <a href="@Url.Action("Delete", "Applicants", new { id = item.Id })"
                           onclick="return confirm('Delete @item.FirstName @item.LastName ?');"
                           class="delete-btn">
                            Delete
                        </a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
    ```

</div>

<style>

    .table-container {
        background: var(--dark2);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 25px;
        margin: 25px;
        overflow: hidden;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    h1 {
        font-family: 'Playfair Display', serif;
        color: var(--gold);
        font-size: 38px;
        margin: 0;
    }

    .btn-gold {
        background: var(--gold);
        color: var(--dark);
        text-decoration: none;
        padding: 12px 22px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-gold:hover {
            opacity: .9;
            color: var(--dark);
        }

    .table {
        width: 100%;
        border-collapse: collapse;
        background: transparent;
    }

        .table thead {
            background: var(--dark3);
        }

            .table thead th {
                padding: 18px;
                color: var(--gold);
                font-family: 'Playfair Display', serif;
                border-bottom: 1px solid var(--border);
                text-align: left;
                font-size: 15px;
            }

        .table tbody td {
            padding: 16px 18px;
            color: var(--text);
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .table tbody tr {
            transition: .3s;
        }

            .table tbody tr:hover {
                background: rgba(201,168,76,.08);
            }

            .table tbody tr:last-child td {
                border-bottom: none;
            }

    .action-cell {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .details-btn {
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        border: 1px solid #0d6efd;
        color: #0d6efd !important;
        font-size: 13px;
        font-weight: 500;
        transition: .3s;
    }

        .details-btn:hover {
            background: #0d6efd;
            color: white !important;
        }

    .delete-btn {
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        border: 1px solid #dc3545;
        color: #dc3545 !important;
        font-size: 13px;
        font-weight: 500;
        transition: .3s;
    }

        .delete-btn:hover {
            background: #dc3545;
            color: white !important;
        }

    @@media(max-width:768px) {

        .table-container {
            margin: 15px;
            padding: 15px;
        }

        h1 {
            font-size: 28px;
        }

        .table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

</style>
